# ── Blood Bank Backend .env ───────────────────────────────────────────
# Copy to .env — never commit the filled version to GitHub.

# ── Supabase ─────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── JWT Auth ──────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-char-hex

# ── ML Microservice ───────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:5001
ML_SECRET=replace-with-same-value-as-ml-service

# ── Email (Nodemailer via Gmail App Password) ─────────────────────────
EMAIL_FROM=bloodbank@example.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-16-char-app-password   # Gmail → Security → App Passwords

# ── Africa's Talking SMS (free sandbox) ──────────────────────────────
AT_API_KEY=your-africastalking-api-key
AT_USERNAME=sandbox
AT_SENDER_ID=BloodBank

# ── Server ────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
