# ── ML Microservice .env ──────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit the filled-in .env file to GitHub.

# ── Supabase ─────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
# Use the service_role key (bypasses RLS — keep this secret!)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Shared secret between Node.js backend and this ML service ────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ML_SECRET=replace-with-a-strong-random-hex-string

# ── Flask ─────────────────────────────────────────────────────────────
FLASK_ENV=production
PORT=5001

# ── Optional: set to 1 to run without Supabase (uses synthetic data) ─
DEMO_MODE=0
